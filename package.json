{
  "name": "mapapp",
  "version": "1.0.0",
  "description": "Map application",
  "author": "Gianmattia",
  "main": "electron/main.cjs",
  "type": "commonjs",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild",
    "build": "electron-builder --mac --win --publish never",
    "dist": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "better-sqlite3": "^9.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jquery": "^4.0.0"
  },
  "build": {
  "appId": "com.mapapp.desktop",
  "productName": "MapApp",
  "asar": true,
  "directories": {
    "output": "dist",
    "buildResources": "frontend/public/img/icons"
  },
  "files": [
    "frontend/**/*",
    "electron/**/*",
    "backend/**/*",
    "package.json",
    "node_modules/**/*"
  ],
  "mac": {
    "icon": "icon.icns",
    "target": ["dmg", "zip"]
  },
  "win": {
    "icon": "icon.ico",
    "target": "nsis",
    "artifactName": "MapAppSetup-${version}.exe"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
}